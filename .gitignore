# ================================
# 🔒 ENVIRONMENT VARIABLES (CRITICAL)
# ================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# Allow only sample files
!.env.example
!.env.sample

# Private keys / certificates
*.pem
*.key
*.crt

# ================================
# 📦 DEPENDENCIES
# ================================
node_modules/
.pnp/
.pnp.js

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ================================
# 🚀 NEXT.JS / BUILD FILES
# ================================
.next/
out/
build/
dist/
.vercel/
.next/cache/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ================================
# 🧪 TEST / COVERAGE
# ================================
coverage/
.nyc_output/

# ================================
# 🖥️ OS FILES
# ================================
.DS_Store
Thumbs.db

# ================================
# 🧑‍💻 EDITOR / IDE FILES
# ================================
.vscode/
.idea/
*.swp
*.swo

# ================================
# 🔐 MISC SENSITIVE FILES
# ================================
*.log
*.sqlite
*.db

# Local config files
config/local.json

